// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id        Int       @id @default(autoincrement())
  name      String
  category  String    @default("อื่นๆ")
  price     Float
  costPrice Float     @default(0)
  stock     Int       @default(0)
  barcode   String?   @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  saleItems SaleItem[]

  @@map("products")
  @@index([isActive, createdAt])
  @@index([category])
}

model Promotion {
  id               Int           @id @default(autoincrement())
  name             String
  type             PromotionType
  value            Float         @default(0)   // สำหรับ FIXED และ PERCENT
  quantityRequired Int           @default(0)   // สำหรับ BUNDLE
  specialPrice     Float         @default(0)   // สำหรับ BUNDLE
  applicableCategories String[]  @default([])  // หมวดหมู่ที่เข้าร่วมโปรโมชั่น (ถ้าว่างจะถือว่าใช้กับทุกหมวดหมู่)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  sales Sale[]

  @@map("promotions")
}

enum PromotionType {
  FIXED_DISCOUNT    // ลด X บาท
  PERCENT_DISCOUNT  // ลด X%
  BUNDLE            // ซื้อ N ตัว ราคา X บาท
}

model Sale {
  id              Int      @id @default(autoincrement())
  subtotal        Float
  promotionDiscount Float  @default(0)
  manualDiscount  Float    @default(0)
  total           Float
  note            String?
  paymentMethod   String   @default("CASH")
  createdAt       DateTime @default(now())

  promotionId     Int?
  promotion       Promotion? @relation(fields: [promotionId], references: [id])
  items           SaleItem[]

  @@map("sales")
  @@index([createdAt])
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  unitPrice Float
  subtotal  Float

  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
  @@index([saleId])
  @@index([productId])
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // Hashed password
  name      String
  role      String   @default("cashier") // admin, cashier
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model StoreSetting {
  id              Int      @id @default(1)
  storeName       String   @default("หจก.น้องพรีม")
  storeBranch     String   @default("สำนักงานใหญ่ (Branch 00000)")
  storeAddress    String   @default("แขวงเสนานิคม เขตจตุจักร กรุงเทพมหานคร")
  storeTaxId      String   @default("")
  storePhone      String   @default("064-514-5498")
  receiptFooter   String   @default("ขอบคุณที่อุดหนุนสินค้าของเรา / Thank You for Your Business. สินค้าซื้อแล้วไม่รับเปลี่ยนหรือคืน / No Exchange, No Return.")
  enableVat       Boolean  @default(true)
  vatRate         Float    @default(7.0)
  enablePromptpay Boolean  @default(true)
  omiseMode       String   @default("test") // test or live
  omisePublicKey  String   @default("")
  omiseSecretKey  String   @default("")
  updatedAt       DateTime @updatedAt

  @@map("store_settings")
}
